{1.5}
unit MemoryFileUnit;

interface

uses
  System.SysUtils,
  WinApi.Windows;

type
  TMemoryFile = record
    fileHandle:  THandle;
    startAddress: PChar;
  end;

function  CreateMemoryFile(AFileName: String): TMemoryFile;
function  OpenMemoryFile(AFileName: String): TMemoryFile;
procedure CloseMemoryFile(AMemoryFile: TMemoryFile);
function  WireToMemoryFile(AMemoryFile: TMemoryFile; AWriteString: String): Boolean;
function  ReadFromMemoryFile(AMemoryFile: TMemoryFile): String;
function  MemoryFileExists(AFileName: String): Boolean;

function  WireToMemoryFileByName(AFileName: String; AWriteString: String): Boolean;
function  ReadFromMemoryFileByName(AFileName: String): String;

implementation

function CreateMemoryFile(AFileName: String): TMemoryFile;
var
  MemoryFile:     TMemoryFile;
begin
  MemoryFile.fileHandle  := 0;
  MemoryFile.startAddress := nil;
  Result := MemoryFile;

  MemoryFile.fileHandle := CreateFileMapping(INVALID_HANDLE_VALUE, nil, PAGE_READWRITE,
                                0, 8, PWideChar(AFileName));
//                                0, 4, PWideChar(fFileName));

//  MemoryFile.fileHandle := CreateFileMapping(MAXDWORD, nil, PAGE_READWRITE,
//                              0, 4, PWideChar(fFileName));

  if MemoryFile.fileHandle = 0 then
  begin
    MessageBox(0, PWideChar('Can`t create memory file' + ' ' + SysErrorMessage(GetLastError)), 'Error', MB_OK + MB_ICONERROR);

    Exit;
  end;

  MemoryFile.startAddress :=
    MapViewOfFile(MemoryFile.fileHandle, FILE_MAP_ALL_ACCESS, 0, 0, 0);

  if MemoryFile.startAddress = nil then
  begin
    MessageBox(0, PWideChar('Can`t connect memory file' + ' ' + SysErrorMessage(GetLastError)), 'Error', MB_OK + MB_ICONERROR);

    Exit;
  end;

  Result := MemoryFile;
end;

function OpenMemoryFile(AFileName: String): TMemoryFile;
var
  MemoryFile:     TMemoryFile;
begin
  MemoryFile.fileHandle  := 0;
  MemoryFile.startAddress := nil;
  Result := MemoryFile;

  MemoryFile.fileHandle := OpenFileMapping(FILE_MAP_ALL_ACCESS, false, PWideChar(AFileName));

  if MemoryFile.fileHandle = 0 then
  begin
    MessageBox(0, PWideChar('Can`t open memory file' + ' ' + SysErrorMessage(GetLastError)), 'Error', MB_OK + MB_ICONERROR);

    Exit;
  end
  else
  begin
    MemoryFile.startAddress := MapViewOfFile(MemoryFile.fileHandle, FILE_MAP_ALL_ACCESS, 0, 0, 0);

    if MemoryFile.startAddress = nil then
    begin
      MessageBox(0, PWideChar('Can`t connect memory file' + ' ' + SysErrorMessage(GetLastError)), 'Error', MB_OK + MB_ICONERROR);

      Exit;
    end;
  end;

  Result := MemoryFile;
end;

procedure CloseMemoryFile(AMemoryFile: TMemoryFile);
begin
  //Îňęëţ÷čě ôŕéë îň ŕäđĺńíîăî ďđîńňđŕíńňâŕ
  if not UnmapViewOfFile(AMemoryFile.startAddress) then
    MessageBox(0, PWideChar('Can`t unmap memory file' + ' ' + SysErrorMessage(GetLastError)), 'Error', MB_OK + MB_ICONERROR);
  //Îńâîáîćäŕĺě îáúĺęň ôŕéëŕ
  if not CloseHandle(AMemoryFile.fileHandle) then
    MessageBox(0, PWideChar('Can`t close memory file hanle' + ' ' + SysErrorMessage(GetLastError)), 'Error', MB_OK + MB_ICONERROR);
end;

function WireToMemoryFile(AMemoryFile: TMemoryFile; AWriteString: String): Boolean;
begin
  Result := false;

  if AMemoryFile.fileHandle <> 0 then
  begin
    if AMemoryFile.startAddress <> nil then
    begin
      StrPCopy(AMemoryFile.startAddress, AWriteString);

      Result := true;
    end
  end;
end;

function ReadFromMemoryFile(AMemoryFile: TMemoryFile): String;
begin
  Result := '';

  if AMemoryFile.fileHandle <> 0 then
  begin
    if AMemoryFile.startAddress <> nil then
    begin
      Result := String(PChar(AMemoryFile.startAddress));
    end
  end;
end;

function MemoryFileExists(AFileName: String): Boolean;
var
  hFileMapMapObj: THandle;
begin
  Result := false;

  hFileMapMapObj := OpenFileMapping(FILE_MAP_ALL_ACCESS, false, PWideChar(AFileName));
  if hFileMapMapObj <> 0 then
    Result := true
  else
    Exit;

  if not CloseHandle(hFileMapMapObj) then
    MessageBox(0, PWideChar('Can`t close memory file handle' + ' ' + SysErrorMessage(GetLastError)), 'Error', MB_OK + MB_ICONERROR);
end;

function WireToMemoryFileByName(AFileName: String; AWriteString: String): Boolean;
var
  MemoryFile: TMemoryFile;
begin
  Result := false;

  if not MemoryFileExists(AFileName) then
    Exit;

  MemoryFile := OpenMemoryFile(AFileName);
  if MemoryFile.fileHandle = 0 then
    Exit;

  if MemoryFile.startAddress = nil then
  begin
    CloseHandle(MemoryFile.fileHandle);
    Exit;
  end;

  StrPCopy(MemoryFile.startAddress, AWriteString);

  CloseMemoryFile(MemoryFile);

  Result := true;
end;

function ReadFromMemoryFileByName(AFileName: String): String;
var
  MemoryFile: TMemoryFile;
begin
  Result := '';

  if not MemoryFileExists(AFileName) then
    Exit;

  MemoryFile := OpenMemoryFile(AFileName);
  if MemoryFile.fileHandle = 0 then
    Exit;

  if MemoryFile.startAddress = nil then
  begin
    CloseHandle(MemoryFile.fileHandle);
    Exit;
  end;

  Result := String(PChar(MemoryFile.startAddress));

  CloseMemoryFile(MemoryFile);
end;

end.
